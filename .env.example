# AssetRadar environment configuration
#
# Copy this file to `.env` for local development:
#   cp .env.example .env
#
# NEVER commit `.env` — it is gitignored. Real secrets belong in a secret
# manager (Vault / AWS Secrets Manager) in deployed environments.
#
# Phase 1 deployment note: only ETHEREUM_RPC_URL (a dedicated provider) and
# SITE_URL need to be set in production. DATABASE_URL and REDIS_URL are
# OPTIONAL until persistence/caching features ship — nothing on the MVP
# request path uses them.

# --- Runtime -----------------------------------------------------------------
NODE_ENV=development

# --- Site --------------------------------------------------------------------
# Canonical public URL (metadataBase / Open Graph / canonical links). Set this
# once a real production domain exists. When unset, Vercel deployments derive
# it from the deployment's own URL; elsewhere it falls back to localhost.
# SITE_URL=https://example.com

# --- Database (PostgreSQL) — OPTIONAL in Phase 1 ------------------------------
# Matches the `db` service in docker-compose.yml. Required only once
# database-backed features (report persistence) are enabled.
DATABASE_URL=postgresql://assetradar:assetradar@localhost:5432/assetradar

# --- Cache (Redis) — OPTIONAL in Phase 1 --------------------------------------
# Matches the `redis` service in docker-compose.yml. Required only once
# cache-backed features (connector/report caching) are enabled.
REDIS_URL=redis://localhost:6379

# --- Chain access ---------------------------------------------------------------
# Ethereum mainnet RPC. The public default works for development; use a
# dedicated provider (Alchemy/Infura/own node) with an API key in production.
ETHEREUM_RPC_URL=https://cloudflare-eth.com

# --- Logging -----------------------------------------------------------------
# One of: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# --- Internal observability ----------------------------------------------------
# Serve /api/internal/metrics in production (always served in development).
# Deployed environments must also network-restrict /api/internal/*.
INTERNAL_METRICS_ENABLED=false
