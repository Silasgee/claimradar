# AssetRadar environment configuration
#
# Copy this file to `.env` for local development:
#   cp .env.example .env
#
# NEVER commit `.env` — it is gitignored. Real secrets belong in a secret
# manager (Vault / AWS Secrets Manager) in deployed environments.

# --- Runtime -----------------------------------------------------------------
NODE_ENV=development

# --- Database (PostgreSQL) ---------------------------------------------------
# Matches the `db` service in docker-compose.yml.
DATABASE_URL=postgresql://assetradar:assetradar@localhost:5432/assetradar

# --- Cache (Redis) -----------------------------------------------------------
# Matches the `redis` service in docker-compose.yml.
REDIS_URL=redis://localhost:6379

# --- Chain access ---------------------------------------------------------------
# Ethereum mainnet RPC. The public default works for development; use a
# dedicated provider (Alchemy/Infura/own node) with an API key in production.
ETHEREUM_RPC_URL=https://cloudflare-eth.com

# --- Logging -----------------------------------------------------------------
# One of: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# --- Internal observability ----------------------------------------------------
# Serve /api/internal/metrics in production (always served in development).
# Deployed environments must also network-restrict /api/internal/*.
INTERNAL_METRICS_ENABLED=false
